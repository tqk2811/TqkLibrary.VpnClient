# ipsec.secrets — PSK cho IKEv2 lab/ikev2-native.
# Group PSK = "vpn" (khớp default ?psk=vpn của demo TqkLibrary IKEv2).
# '%any %any' : chấp nhận mọi cặp ID (client remote-access, IDi = 0.0.0.0).
%any %any : PSK "vpn"

# (tùy chọn) EAP-MSCHAPv2 user cho --ikev2-eap. Bật khi test đường EAP (V.1(b)).
# Format strongSwan: <id> : EAP "password"
testuser : EAP "testpass"
