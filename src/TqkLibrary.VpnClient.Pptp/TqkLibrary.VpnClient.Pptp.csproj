<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>PPTP (RFC 2637) protocol: TCP/1723 control-connection codec (SCCRQ/SCCRP, OCRQ/OCRP, Echo, Set-Link-Info, Call-Clear/CDN), control-channel state machine, and a CCP negotiator that wires the legacy MPPE option (RFC 3078/3079) into the existing PPP stack. Offline only — the GRE proto-47 data plane needs raw-IP (F.9) and is not built here.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TqkLibrary.VpnClient.Abstractions\TqkLibrary.VpnClient.Abstractions.csproj" />
    <ProjectReference Include="..\TqkLibrary.VpnClient.Crypto\TqkLibrary.VpnClient.Crypto.csproj" />
    <ProjectReference Include="..\TqkLibrary.VpnClient.Ppp\TqkLibrary.VpnClient.Ppp.csproj" />
  </ItemGroup>

</Project>
